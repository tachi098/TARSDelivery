<div class="container-fluid mt-3">
    <div class="col-lg-12">
        <div class="col-lg-12">
            <h2>Create employee</h2>
            <form asp-action="Create" asp-controller="Branch" asp-area="Admin">
                <div class="form-group">
                    <label class="small mb-1" >Name</label>
                    <input class="form-control py-4"  type="text" placeholder="Enter Name" asp-for="Name" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Address" class="control-label"></label>
                    <input asp-for="Address" class="form-control" placeholder="Enter Address" />
                    <span asp-validation-for="Address" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Phone" class="control-label"></label>
                    <input asp-for="Phone" class="form-control" placeholder="Enter Phone" />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>

        
              
                <div class="form-group mt-4 mb-0"><input type="submit" class="btn btn-primary btn-block" value="Create " /></div>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}




